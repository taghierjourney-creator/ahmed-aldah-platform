{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "rules": {
    // Enforced in CI under NODE_ENV=production; local dev uses eslint.config.mjs which sets rule to warn
    "no-console": "error"
  },
  "overrides": [
    {
      "files": ["tests/**"],
      "rules": {
        "no-console": "off",
        "@typescript-eslint/no-require-imports": "off"
      }
    }
  ]
}
