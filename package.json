{
  "name": "ahmed-aldah-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run lint:ci && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:preview": "prisma migrate deploy",
    "test:a11y": "node tests/a11y/run-axe.js"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.12.0",
    "@sentry/nextjs": "^10.66.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.2",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/speakeasy": "^2.0.10",
    "axe-playwright": "^2.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.38.0",
    "prisma": "^5.12.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
