datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Role enum required by strict RBAC
enum Role {
  ADMIN
  EDITOR
  MODERATOR
  USER
  CLIENT
  AUTHOR
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// NextAuth-compatible schema with role on the User model
model User {
  id               String         @id @default(cuid())
  name             String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  avatar           String?
  bio              String?
  role             Role           @default(USER)
  canPublish       Boolean        @default(false)
  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)
  accounts         Account[]
  sessions         Session[]
  requests         ClientRequest[]
  documents        Document[]
  articles         Article[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Client {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String    @id @default(cuid())
  sessionToken  String    @unique
  userId        String
  expires       DateTime
  mfaVerifiedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientRequest {
  id          String        @id @default(cuid())
  title       String
  description String
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@index([userId])
}

model Document {
  id           String        @id @default(cuid())
  storagePath  String        @unique
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime      @default(now())
  requestId    String
  userId       String
  clientRequest ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// CMS models: Category, Tag, Series, Article (TSK-1.1)
model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String
  locale    String
  articles  Article[] @relation("CategoryArticles")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([locale, slug])
  @@index([locale])
  @@index([deletedAt])
}

model Tag {
  id        String    @id @default(uuid())
  name      String
  slug      String
  locale    String
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([locale, slug])
  @@index([locale])
  @@index([deletedAt])
}

model Series {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  slug        String
  locale      String
  articles    Article[] @relation("SeriesArticles")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([locale, slug])
  @@index([locale])
  @@index([deletedAt])
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
}

model Article {
  id                    String       @id @default(uuid())
  title                 String
  slug                  String
  excerpt               String?
  coverImage            String?
  content               String       @db.Text
  audioUrl              String?
  published             Boolean      @default(false)
  status                ArticleStatus @default(DRAFT)
  views                 Int          @default(0)
  publishedAt           DateTime?
  locale                String
  translationGroupId    String       @default(uuid())
  normalizedTitle       String       @default("")
  normalizedDescription String       @default("")
  normalizedContent     String       @default("")

  authorId String?
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation("CategoryArticles", fields: [categoryId], references: [id], onDelete: SetNull)

  seriesId String?
  series   Series? @relation("SeriesArticles", fields: [seriesId], references: [id], onDelete: SetNull)

  tags Tag[]

  comments Comment[]
  versions ArticleVersion[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([locale, slug])
  @@index([locale])
  @@index([translationGroupId])
  @@index([deletedAt])
  @@index([normalizedTitle, normalizedDescription])
}

model ArticleVersion {
  id            String   @id @default(uuid())
  articleId     String
  locale        String
  content       Json
  savedAt       DateTime @default(now())
  versionNumber Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([locale])
  @@unique([articleId, versionNumber])
}
// Office models: Service, Project (TSK-2.1)
model Service {
  id          String   @id @default(uuid())
  slug        String
  title       String
  description String   @db.Text
  locale      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, slug])
}

model Project {
  id          String   @id @default(uuid())
  slug        String
  title       String
  description String   @db.Text
  locale      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, slug])
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

model Comment {
  id        String        @id @default(uuid())
  content   String        @db.Text
  status    CommentStatus @default(PENDING)
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([articleId])
  @@index([status])
}

model AuditLogEntry {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())
}

model RedirectRule {
  id        String   @id @default(cuid())
  oldSlug   String
  newSlug   String
  locale    String
  createdAt DateTime @default(now())

  @@unique([locale, oldSlug])
}
